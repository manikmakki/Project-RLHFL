FROM nvidia/cuda:11.8.0-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
#ENV LD_LIBRARY_PATH=/usr/local/cuda/lib64:/usr/local/lib/python3.10/dist-packages/llama_cpp
ENV PATH=/usr/local/cuda-11.8/compat/:$PATH

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3.10 \
    python3-pip \
    git \
    wget \
    cmake \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip
RUN python3 -m pip install --upgrade pip

# Install NumPy < 2.0 (compatibility)
RUN pip install --no-cache-dir "numpy<2.0"

# Install PyTorch 2.5.1 with CUDA 11.8 (supports CC 6.1, includes set_submodule for bitsandbytes)
RUN pip install --no-cache-dir \
    torch==2.5.1 \
    torchvision==0.20.1 \
    --index-url https://download.pytorch.org/whl/cu118

# Install training dependencies
# transformers 5.0.0 adds gpt_oss model support (required for GPT-OSS/Jinx models)
# tokenizers 0.22.2 for transformers 5.0.0 compatibility
# sentence-transformers 5.2.2 requires PyTorch ≥2.2 (upgraded to 2.5.1)
# datasets 3.0.0 for huggingface_hub >=1.3.0 compatibility (transformers 5.0.0 requirement)
# accelerate 1.3.0 for transformers 5.0.0 and bitsandbytes 0.49.1 compatibility
# bitsandbytes 0.49.1 for 4-bit quantization with Params4bit fixes
RUN pip install --no-cache-dir \
    transformers==5.0.0 \
    tokenizers==0.22.2 \
    peft==0.18.1 \
    trl==0.7.4 \
    bitsandbytes==0.49.1 \
    accelerate==1.3.0 \
    datasets==3.0.0 \
    chromadb==0.4.18 \
    sentence-transformers==5.2.2 \
    apscheduler==3.10.4 \
    pydantic==2.5.0 \
    pydantic-settings==2.1.0 \
    PyYAML==6.0.1 \
    scipy==1.11.4 \
    httpx

# Install llama-cpp-python with CUDA support for CC 6.1
RUN CMAKE_ARGS="-DLLAMA_CUBLAS=on -DCMAKE_CUDA_ARCHITECTURES=61" pip install --no-cache-dir llama-cpp-python==0.2.27

# Install GGUF conversion dependencies
RUN pip install --no-cache-dir sentencepiece requests

# Build llama-quantize binary and grab convert script from llama.cpp b3400.
# Pinned tag ensures compatibility with PyTorch 2.0.1 (no torch.uint64/float8).
# Install the gguf Python package from the SAME tag so script + lib stay in sync.
RUN mkdir -p /app/bin /app/scripts && \
    git clone --depth 1 --branch b3400 https://github.com/ggml-org/llama.cpp.git /tmp/llama.cpp && \
    cp /tmp/llama.cpp/convert_hf_to_gguf.py /app/scripts/convert_hf_to_gguf.py && \
    pip install --no-cache-dir /tmp/llama.cpp/gguf-py && \
    cd /tmp/llama.cpp && \
    mkdir build && cd build && \
    cmake .. -DGGML_CUDA=ON -DCMAKE_CUDA_ARCHITECTURES=61 -DBUILD_SHARED_LIBS=OFF && \
    cmake --build . --target llama-quantize -j$(nproc) && \
    cp bin/llama-quantize /app/bin/llama-quantize && \
    cd / && rm -rf /tmp/llama.cpp

ENV LD_LIBRARY_PATH=/usr/local/cuda/lib64

WORKDIR /app

# Copy application code - INCLUDE API for MemoryManager access
COPY services/api /app/api
COPY services/trainer /app/trainer
COPY services/shared /app/shared

# Create necessary directories
RUN mkdir -p /data /models /checkpoints /config

# Set environment to disable telemetry
ENV ANONYMIZED_TELEMETRY=False

CMD ["python3", "-m", "trainer.trainer_worker"]